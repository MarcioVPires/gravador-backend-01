# Conexão Postgres do Supabase — use o POOLER (transaction mode, porta 6543).
# (Pegue em: Supabase > Project Settings > Database > Connection string > "Transaction pooler".)
SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Segredo para autenticar o webhook do Supabase (header X-Webhook-Secret). Gere um valor forte.
WEBHOOK_SECRET=

# Concorrência máxima de tarefas de IA em processo (semáforo). DEC-019.
MAX_CONCURRENCY=1

# Chaves de IA — os NOMES batem com ai_services.key_env (DEC-021). Valores vêm do chaves.md.
# (No deploy vão para o env do Cloud Run; NUNCA para o DB nem para o git.)
GROQ_LEARION=
GROQ_GERALDO=
GROQ_LENDARIO=
GROQ_MARCIO=
OPENAI_EVERTON=
GOOGLE_EVERTON=
KIE_LEARION=
