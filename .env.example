# Conexão Postgres do Supabase — use o POOLER (transaction mode, porta 6543), SEM a senha na URL.
# (Supabase > Connect > "Transaction pooler". Remova o ":<senha>" — ela vai na var separada abaixo.)
SUPABASE_DB_URL=postgresql://postgres.<ref>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Senha do banco SEPARADA (literal, NÃO encodar) — aceita qualquer caractere especial.
SUPABASE_DB_PASSWORD=

# Segredo para autenticar o webhook do Supabase (header X-Webhook-Secret). Gere um valor forte.
WEBHOOK_SECRET=

# Concorrência máxima de tarefas de IA em processo (semáforo). DEC-019.
MAX_CONCURRENCY=1

# Chaves de IA — os NOMES batem com ai_services.key_env (DEC-021). Valores vêm do chaves.md.
# (No deploy vão para o env do Cloud Run; NUNCA para o DB nem para o git.)
GROQ_LEARION=
GROQ_GERALDO=
GROQ_LENDARIO=
GROQ_MARCIO=
OPENAI_EVERTON=
GOOGLE_EVERTON=
KIE_LEARION=
